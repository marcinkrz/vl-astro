---
import { getT, type Locale } from '@/i18n/messages';
import { getRoute } from '@/i18n/routes';
import LangSwitch from './LangSwitch.astro';
import Button from './_ui/Button.astro';
import Logo from './_ui/Logo.astro';

const locale = (Astro.currentLocale === 'pl' ? 'pl' : 'en') as Locale;
const t = getT(locale);
---

<header class="relative z-[100] container h-12 mx-auto pt-2 grid grid-cols-[1fr_auto_auto] items-start gap-x-2 leading-none">
  <Logo />
  <LangSwitch />
  <Button
    href={getRoute(locale, 'contact')}
    variant="primary"
    size="small"
    class=""
  >{t('nav.contact')}</Button>
</header>
