---
import { getT, type Locale } from '@/i18n/messages';
import { getRoute } from '@/i18n/routes';

const locale = (Astro.currentLocale === 'pl' ? 'pl' : 'en') as Locale;
const t = getT(locale);

const pathname = Astro.url.pathname;

const items = [
  { key: 'projects', href: getRoute(locale, 'projects'), label: t('nav.projects') },
  { key: 'studio', href: getRoute(locale, 'studio'), label: t('nav.studio') },
  { key: 'contact', href: getRoute(locale, 'contact'), label: t('nav.contact') },
] as const;

const isActive = (href: string) => pathname === href || pathname.startsWith(`${href}/`);
---

<header class="relative z-[100] container mx-auto">
  <div class="h-12 pt-2 flex justify-between leading-none">
    <a href={getRoute(locale, 'home')}>Visual Label</a>
    <nav>
      <ul class="flex gap-4">
        {items.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
              class:list={{
                'text-[var(--foreground)]': isActive(item.href),
                'text-[var(--muted)]': !isActive(item.href),
              }}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
  </div>
</header>
