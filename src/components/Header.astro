---
import { getT, type Locale } from '@/i18n/messages';
import { getRoute } from '@/i18n/routes';
import LangSwitch from './LangSwitch.astro';
import Button from './_ui/Button.astro';
import Logo from './_ui/Logo.astro';

const locale = (Astro.currentLocale === 'pl' ? 'pl' : 'en') as Locale;
const t = getT(locale);

const pathname = Astro.url.pathname;

const items = [
  { key: 'projects', href: getRoute(locale, 'projects'), label: t('nav.projects') },
  { key: 'studio', href: getRoute(locale, 'studio'), label: t('nav.studio') },
  { key: 'contact', href: getRoute(locale, 'contact'), label: t('nav.contact') },
] as const;

const isActive = (href: string) => pathname === href || pathname.startsWith(`${href}/`);
---
<header class="container">
  <div class="fixed z-[101] top-2 max-md:inset-x-2 flex justify-between mix-blend-difference">
    <Logo />
    <Button
      id="menu-toggle"
      variant="ghost"
      size="icon"
      aria-label="Menu"
      class={`md:hidden relative p-0 w-12 h-12 -mt-2 hover:bg-transparent focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white active:bg-transparent
      group
      `}
    >
      <span class={
        `before:block before:absolute before:w-3/4 before:h-[3px] before:bg-white
        before:top-2 before:right-0
        group-[.is-active]:before:w-3/4
        group-[.is-active]:before:top-[50%]
        group-[.is-active]:before:-right-5
        group-[.is-active]:before:rotate-[135deg]
        group-[.is-active]:before:translate-[-50%]
        before:transition-all before:duration-400 before:ease-in-out

        after:block after:absolute after:w-3/4 after:h-[3px] after:bg-white
        after:top-7 after:right-0
        group-[.is-active]:after:w-3/4
        group-[.is-active]:after:top-[50%]
        group-[.is-active]:after:-right-5
        group-[.is-active]:after:rotate-[225deg]
        group-[.is-active]:after:translate-[-50%]
        after:transition-all after:duration-400 after:ease-in-out
        `}>
          <span class={`
          block absolute w-3/4 h-[3px] bg-white
          top-4 right-0
          group-[.is-active]:w-1
          group-[.is-active]:top-[50%]
          group-[.is-active]:right-3
          group-[.is-active]:rotate-[360deg]
          group-[.is-active]:-translate-y-1/2
          transition-all duration-400 ease-in-out
          `}></span>
        </span>
    </Button>
  </div>

  <nav
    id="menu-items"
    class={`
      fixed z-[100] top-0 inset-x-0 h-[100svh] text-white
      invisible
      [.is-active]:visible
      transition-visible duration-300
      group
    `}>
    <ul class={`
      absolute z-1 top-[50%] left-[50%] flex flex-col gap-4 text-center
      opacity-0
      translate-x-[-50%]
      translate-y-[-25%]
      group-[.is-active]:opacity-100
      group-[.is-active]:translate-y-[-50%]
      transition-all duration-300
      mix-blend-difference
    `}>
      {items.map((item) => (
        <li>
          <a href={item.href} class="text-[4rem] font-semibold">
            {item.label}
          </a>
        </li>
      ))}
      <li class="mt-12">
        <LangSwitch />
      </li>
    </ul>
    <div class={`
      absolute inset-0 bg-[var(--background)]
      opacity-0
      group-[.is-active]:opacity-100
      transition-opacity duration-300
    `}></div>
  </nav>

  <div class="hidden md:flex gap-x-4 fixed z-[100] top-2 right-2 md:right-4 lg:right-6 w-full justify-end">
    <nav>
      <ul class="flex h-full items-center gap-4 font-semibold">
        {items.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
              class:list={{
                'text-[var(--foreground)]': isActive(item.href),
                'text-[var(--muted)]': !isActive(item.href),
              }}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <LangSwitch />
  </div>
</header>
<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const toggleButton = document.getElementById('menu-toggle');
    const menuItems = document.getElementById('menu-items');

    toggleButton?.addEventListener('click', () => {
      toggleButton?.classList.toggle('is-active');
      menuItems?.classList.toggle('is-active');
    });
  });
</script>
