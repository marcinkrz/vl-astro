---
import Button from '@/components/_ui/Button.astro';
import { getCollection } from 'astro:content';
import type { Locale } from '@/i18n/messages';
import { getOtherLocale, getRoute } from '@/i18n/routes';
import { getT } from '@/i18n/messages';

const currentLocale = (Astro.currentLocale === 'pl' ? 'pl' : 'en') as Locale;
const targetLocale = getOtherLocale(currentLocale);
const currentPath = Astro.url.pathname.replace(/\/$/, '');

const t = getT(currentLocale);

const routeCandidates = ['home', 'projects', 'studio', 'contact'] as const;

let href = getRoute(targetLocale, 'home');

for (const key of routeCandidates) {
  if (currentPath === getRoute(currentLocale, key)) {
    href = getRoute(targetLocale, key);
    break;
  }
}

const currentProjectsBase = getRoute(currentLocale, 'projects');
const targetProjectsBase = getRoute(targetLocale, 'projects');

if (currentPath.startsWith(`${currentProjectsBase}/`)) {
  const currentSlug = currentPath
    .replace(`${currentProjectsBase}/`, '')
    .replace(/\/$/, '');

  const projects = await getCollection('projects');

  const currentProject = projects.find(
    (entry) =>
      entry.data.locale === currentLocale &&
      entry.id === currentSlug
  );

  if (currentProject) {
    const translatedProject = projects.find(
    (entry) =>
      entry.data.projectKey === currentProject.data.projectKey &&
      entry.data.locale === targetLocale
    );

    href = translatedProject
      ? `${targetProjectsBase}/${translatedProject.id}`
      : targetProjectsBase;
  }
}
---
<Button
  href={href}
  data-language-switcher
  data-target-locale={targetLocale}
  aria-label={t('footer.srLocale')}
  title={t('footer.srLocale')}
  variant="outline"
  size="small"
  class="pl-0.5 pr-2 max-md:text-white"
>
  <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><g transform="matrix(.83 0 0 .83 -.45 -.45)"><path d="M15 3C8.384 3 3 8.384 3 15s5.384 12 12 12 12-5.384 12-12S21.616 3 15 3m0 2c.393 0 .8.163 1.266.596s.946 1.13 1.359 2.039c.307.674.557 1.492.773 2.365h-6.796c.216-.873.466-1.69.773-2.365.413-.908.894-1.606 1.36-2.04C14.2 5.164 14.606 5 15 5m-3.912.793c-.188.32-.37.655-.533 1.016-.428.94-.771 2.02-1.03 3.191H6.344a10 10 0 0 1 4.744-4.207m7.824 0A10 10 0 0 1 23.656 10h-3.181c-.259-1.172-.602-2.25-1.03-3.191a11 11 0 0 0-.533-1.016M5.457 12h3.729C9.068 12.96 9 13.962 9 15s.068 2.04.186 3H5.457A10 10 0 0 1 5 15c0-1.046.161-2.053.457-3m5.766 0h7.554c.13.954.223 1.947.223 3s-.092 2.046-.223 3h-7.554A22 22 0 0 1 11 15c0-1.053.092-2.046.223-3m9.591 0h3.729c.296.947.457 1.954.457 3s-.161 2.053-.457 3h-3.729c.118-.96.186-1.962.186-3s-.068-2.04-.186-3m-14.47 8h3.181c.259 1.172.602 2.25 1.03 3.191.164.361.345.695.533 1.016A10 10 0 0 1 6.344 20m5.258 0h6.796c-.216.873-.466 1.69-.773 2.365-.413.908-.894 1.606-1.36 2.04-.465.432-.872.595-1.265.595s-.8-.163-1.266-.596-.946-1.13-1.359-2.039c-.307-.674-.557-1.492-.773-2.365m8.873 0h3.181a10 10 0 0 1-4.744 4.207c.188-.32.37-.655.533-1.016.428-.94.771-2.02 1.03-3.191" style="stroke:none;stroke-width:1;stroke-dasharray:none;stroke-linecap:butt;stroke-dashoffset:0;stroke-linejoin:miter;stroke-miterlimit:4;fill:currentColor;fill-rule:nonzero;opacity:1"/></g></svg>
  <span>&nbsp;{targetLocale === 'pl' ? ( 'Polski' ) : ( 'English' )}</span>
</Button>
<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const links = document.querySelectorAll('[data-language-switcher]');

    links.forEach((link) => {
      if (link.dataset.langSwitcherBound === '1') return;
      link.dataset.langSwitcherBound = '1';

      link.addEventListener('click', () => {
        const targetLocale = link.getAttribute('data-target-locale');
        if (targetLocale) {
          localStorage.setItem('preferredLanguage', targetLocale);
        }
      });
    });
  });
</script>
