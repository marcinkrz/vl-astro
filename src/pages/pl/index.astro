---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout
  title="Visual Label — Studio kreatywne"
  description="Studio projektowe tworzące nowoczesne strony internetowe."
>
  <main transition:animate="slide">
    <section class="-mt-12 pb-12 h-[75vh] flex items-end border-b border-[var(--border)]">
      <div class="container mx-auto">
        <h1 class="h1 text-pretty md:max-w-[75%] lg:max-w-[66%]">Budowanie pożądanego wizerunku marki, w sieci i poza nią.</h1>
      </div>
    </section>
  </main>
</BaseLayout>
