---
import { getT } from "@/i18n/messages";
import { getRoute } from '@/i18n/routes';
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Button from "@/components/_ui/Button.astro";

const locale = Astro.currentLocale === "pl" ? "pl" : "en";
const t = getT(locale);

const projects = await getCollection(
  "projects",
  ({ data }) => data.locale === "en",
);

projects.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---
<BaseLayout
  title="Visual Label — Creative Studio"
  description="Creative studio building modern websites."
>
  <main class="container">
    <section class="-mt-12 pb-12 h-[75vh] flex items-end">
      <h1 class="h1 text-pretty md:max-w-[75%] lg:max-w-[66%]">
        Creating the desired brand image, online and beyond.
      </h1>
    </section>
    <section class="border-t border-[var(--border)]">
      <Button
        href={getRoute(locale, 'projects')}
        variant="link"
        class="mt-2 mb-12"
      >
        {t("projects.btnTitle")}
      </Button>
      <ul class="space-y-8 mb-24">
      {
        projects.map((project) => (
          <li>
            <a href={`/projects/${project.id}`}>
              <article>
                <img
                  transition:name={`project-cover-${project.data.slug}`}
                  src={project.data.cover}
                  alt={project.data.title}
                />
                <div class="grid grid-cols-4 gap-2">
                  <h2
                    class="h4"
                    transition:name={`project-title-${project.data.slug}`}
                  >{project.data.title}</h2>
                  <p
                    class="col-span-3 text-[var(--muted)]"
                    transition:name={`project-desc-${project.data.slug}`}
                  >
                    {project.data.description}
                  </p>
                </div>
              </article>
            </a>
          </li>
        ))
      }
    </ul>
    </section>
  </main>
</BaseLayout>
