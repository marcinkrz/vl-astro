---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { getT, type Locale } from '@/i18n/messages';
import LangDetect from '@/components/LangDetect.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { fade } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}

const {
  title,
  description,
} = Astro.props as Props;

const locale = (Astro.currentLocale === 'pl' ? 'pl' : 'en') as Locale;
const t = getT(locale);

const siteName = 'Visual Label';

const defaultTitle =
  locale === 'pl'
    ? 'Visual Label — Studio kreatywne'
    : 'Visual Label — Creative Studio';

const defaultDescription =
  locale === 'pl'
    ? 'Studio projektowe tworzące nowoczesne strony internetowe.'
    : 'Creative studio building modern websites.';

const pageTitle = title ? `${title} | ${siteName}` : defaultTitle;
const pageDescription = description ?? defaultDescription;
---
<!doctype html>
<html lang={locale} transition:name="root" transition:animate="none">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={locale === 'pl' ? 'pl_PL' : 'en_US'} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
    <ClientRouter />
	</head>
  <body>
    <LangDetect />
    <Header />
    <main transition:animate={fade({ duration: "0.3s" })}>
      <slot />
    </main>
    <Footer />
    <figure
  class="fixed inset-0 z-10 pointer-events-none opacity-15 mix-blend-difference"
  aria-hidden="true"
>
  <svg
    class="w-full h-full"
    xmlns="http://www.w3.org/2000/svg"
    preserveAspectRatio="none"
  >
    <filter id="noise">
      <feTurbulence
        type="fractalNoise"
        baseFrequency="0.8"
        numOctaves="4"
        stitchTiles="stitch"
      />
    </filter>

    <rect
      width="100%"
      height="100%"
      filter="url(#noise)"
    />
  </svg>
</figure>
	</body>
</html>
