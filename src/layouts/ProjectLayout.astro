---
import BaseLayout from './BaseLayout.astro';
import { getT } from '@/i18n/messages';

const locale = Astro.currentLocale === 'pl' ? 'pl' : 'en';
const t = getT(locale);

interface Props {
  metaTitle: string;
  metaDescription: string;
  title: string;
  description: string;
  client: string;
  cover?: string;
  tags?: string[];
  slug?: string;
  pubDate?: Date;
}

const {
  metaTitle,
  metaDescription,
  title,
  description,
  client,
  cover,
  tags = [],
  slug,
  pubDate,
} = Astro.props as Props;
---
<BaseLayout title={metaTitle} description={metaDescription}>
  <main>
    <article>
      <header class="h-[100svh]">
        {cover && (
          <img transition:name={`project-cover-${slug}`} src={cover} alt={title} class="fixed -z-1 inset-0 w-full h-full object-cover" />
        )}
        <div class="absolute inset-x-0 bottom-12 container mix-blend-difference text-white">
          <h1 transition:name={`project-title-${slug}`} class="display mb-3">{title}</h1>
          <p>{t('project.clientTitle')}: {client}</p>
        </div>
      </header>
      <section class="relative z-1 pt-12 pb-6 container bg-[var(--background)]">
        <p transition:name={`project-desc-${slug}`}>{description}</p>
      </section>
      <section class="relative z-1 container py-6 bg-[var(--background)]">
        <slot />
      </section>
      <footer class="relative z-1 container pt-6 pb-24 bg-[var(--background)]">
        <p>
            {pubDate ? pubDate.toLocaleDateString(locale, {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              }) : null}
          </p>
        <ul>
          <li>{t('project.clientTitle')}: {client}</li>
          {tags.length > 0 && (
            <li>{t('project.tagsTitle')}:
              {tags.map((tag, index) => (
                <span>
                  <span class="text-[var(--foreground)]">{tag}</span>{index < tags.length - 1 ? ', ' : ''}
                </span>
              ))}
            </li>
          )}
        </ul>
      </footer>
    </article>
  </main>
</BaseLayout>
