---
import BaseLayout from './BaseLayout.astro';
import { getT } from '@/i18n/messages';

const locale = Astro.currentLocale === 'pl' ? 'pl' : 'en';
const t = getT(locale);

interface Props {
  metaTitle: string;
  metaDescription: string;
  title: string;
  description: string;
  client: string;
  cover?: string;
  tags?: string[];
  slug?: string;
}

const {
  metaTitle,
  metaDescription,
  title,
  description,
  client,
  cover,
  tags = [],
  slug,
} = Astro.props as Props;
---
<BaseLayout title={metaTitle} description={metaDescription}>
  <main class="container">
    <article>
      <section class="relative w-full max-md:h-[calc(100svh-3rem)] overflow-hidden">
        <div class="max-md:absolute inset-0 max-md:flex flex-col justify-end md:mt-32">
          <h1 transition:name={`project-title-${slug}`} class="display mb-1">{title}</h1>
          <p transition:name={`project-desc-${slug}`} class="mb-6 text-[var(--muted)]">{description}</p>
          {cover && (
            <img transition:name={`project-cover-${slug}`} src={cover} alt={title} class="mb-2 w-full object-cover" />
          )}
          <ul class="mt-6 mb-12 text-[var(--muted)]">
            <li>{t('project.clientTitle')}: {client}</li>
            {tags.length > 0 && (
              <li>{t('project.clientTitle')}:
                {tags.map((tag) => (
                  <span class="text-[var(--foreground)]">
                    {tag}
                  </span>
                ))}
              </li>
            )}
          </ul>
        </div>
      </section>
      <section class="my-12">
        <slot />
      </section>
    </article>
  </main>
</BaseLayout>
