---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  metaTitle: string;
  metaDescription: string;
  client: string;
  lead: string;
  cover?: string;
  tags?: string[];
}

const {
  title,
  metaTitle,
  metaDescription,
  client,
  lead,
  cover,
  tags = [],
} = Astro.props as Props;
---

<BaseLayout title={metaTitle} description={metaDescription}>
  <article class="container mx-auto py-12">
    {cover && (
      <img
        src={cover}
        alt={title}
        class="mb-8 w-full rounded-2xl object-cover"
      />
    )}

    <header class="max-w-3xl">
      <p class="mb-3 text-sm text-[var(--muted)]">Client: {client}</p>
      <h1 class="text-4xl font-semibold">{title}</h1>
      <p class="mt-4 text-lg text-[var(--muted)]">{lead}</p>
    </header>

    <div class="prose mt-10 max-w-3xl">
      <slot />
    </div>

    {tags.length > 0 && (
      <footer class="mt-10 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="rounded-full border px-3 py-1 text-sm">
            {tag}
          </span>
        ))}
      </footer>
    )}
  </article>
</BaseLayout>
