---
import BaseLayout from './BaseLayout.astro';
import { getT } from '@/i18n/messages';

const locale = Astro.currentLocale === 'pl' ? 'pl' : 'en';
const t = getT(locale);

interface Props {
  metaTitle: string;
  metaDescription: string;
  title: string;
  description: string;
  client: string;
  cover?: string;
  tags?: string[];
  slug?: string;
  pubDate?: Date;
}

const {
  metaTitle,
  metaDescription,
  title,
  description,
  client,
  cover,
  tags = [],
  slug,
  pubDate,
} = Astro.props as Props;
---
<BaseLayout title={metaTitle} description={metaDescription}>
  <main class="container mt-12 mb-24">
    <article>
      <header>
        <div class="pb-[75%] relative overflow-hidden"> 
          {cover && (
            <img transition:name={`project-cover-${slug}`} src={cover} alt={title} class="absolute inset-0 w-full h-full object-cover" />
          )}
        </div>

        <!-- <h1
          transition:name={`project-title-${slug}`}
          class="display mt-6 mb-3"
        >
          {title}
        </h1> -->
        
        <p class="my-6 h2">{description}</p>

        <ul class="text-sm">
          <li class="grid grid-cols-[4rem_auto]">
            <span>{t('project.clientTitle')}:</span> {client}
          </li>
          {tags.length > 0 && (
            <li class="grid grid-cols-[4rem_auto]">
              {t('project.tagsTitle')}:
              <span>
                {tags.map((tag, index) => (
                  <span class="">
                    <span class="text-[var(--foreground)]">{tag}</span>{index < tags.length - 1 ? ', ' : ''}
                  </span>
                ))}
              </span>
            </li>
          )}
          <li class="grid grid-cols-[4rem_auto]">
            <span>{t('project.yearTitle')}:</span>
            {pubDate ? pubDate.toLocaleDateString(locale, {
              year: 'numeric'
            }) : null}
          </li>
        </ul>
      </header>

      <section class="relative z-1 py-6 bg-[var(--background)]">
        <slot />
      </section>

      <footer class="relative z-1 pt-6 pb-24 bg-[var(--background)] text-sm">
        <ul>
          <li>{t('project.clientTitle')}: {client}</li>
          {tags.length > 0 && (
            <li>{t('project.tagsTitle')}:
              {tags.map((tag, index) => (
                <span>
                  <span class="text-[var(--foreground)]">{tag}</span>{index < tags.length - 1 ? ', ' : ''}
                </span>
              ))}
            </li>
          )}
        </ul>
      </footer>
    </article>
  </main>
</BaseLayout>
